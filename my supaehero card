<html>
    <head>
        <title>my suparhero card</title>
    <style>
        body {
            background-color: darkblue;
            color: white;
            font-family: Arial, sans-serif;
        }
        .hero-name {
            font-size: 60px;
            font-weight: bold;
            color: yellow;
            text-shadow: 3px 3px orange;
        }
        .tagline {
            font-style: italic;
            color: lightblue;
            text-transform: capitalize;
        }
        .lable {
            text-transform: uppercase;
            text-decoration: underline;
            color: coral;
        }
        .power {
            font-weight: bold;
            color: lightgreen;
        }
        .weakness {
            text-decoration: line-throught;
            color: gray;
        }
        .badge {
            font-size: 28px;
            font-weight: bold;
            color: gold;
            transform: rotate(15deg);
        }
        .made by {
            color: coral;
            font-style: italic;
        }
    </style>
</head>
<body>
    <h1 class="hero name">thunder kids</h1>
    <p class="tagline">the most powerfull hero in the school</p>
    <h2 class="lable">superhero powers</h2>
    <p class="power">can run faster than a cheetah</p>
    <p class="power">can lift a school bus</p>
    <h2 class="lable">weaknesses</h2>
    <p class="weakness">maths homework</p>
    <p class="weakness">broccoli</p>
    <p class="badge">top hero</p>
    <p class="made-by">created by Harshika</p>
</body>
</html>