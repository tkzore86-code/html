<html>
    <head>
        <title>my animal fact file</title>
        <style>
            body {
                background-color: darkgreen;
                font-family: Arial, sans-serif;
            }
            .fact-file {
                background-color: lightyellow;
                color: darkslategray;
                width: 260;
                padding: 25px;
                border: 4px solid forestgreen;
                margin: 30px;
            }
            .animal-name {
                color: forestgreen;
                font-size: 22px;
            }
            .detail {
                color: darkslategray;
            }
            .cool-fact {
                color: darkorange;
                font-style: italic;
            }
        </style>
    </head>  
<body>
<div class="fact-file">
    <h2 class="animal-name">snow leopard</h2>
    <p class="detail">type: big cat</p>
    <p class="detail">lives in: mountain ranges of central asia</p>
    <p class="detail">diet: deer, goats, and wild sheep</p>
    <p class="cool-fact">cool fact: can leap up to 15 metres in one jump!</p>
</div>
</body>
</html>