<html>
<head>
  <title>My dream career</title>
  <style>
     {
      box-sizing: border-box;
    }
    body {
      font-family: Georgia, serif;
      background-color: #fff8e7;
      color: #3b2f2f;
    }
    .menu-card {
      width: 600px;
      border: 3px solid #8b4513;
      border-radius: 15px;
      background-color: #ffffff;
      box-shadow: 0 0 20px #8b4513;
    }
    .restaurant-name {
      font-size: 42px;
      font-weight: bold;
      color: #8b0000;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 3px;
      text-shadow: 2px 2px 4px #d2b48c;
    }
    .tagline {
      font-size: 18px;
      font-style: italic;
      text-align: center;
      color: #6b4226;
      text-decoration: underline;
    }
    .menu-section {
      border: 2px solid #d2b48c;
      box-shadow: 0 0 8px #d2b48c;
    }
    .section-title {
      font-size: 26px;
      color: #a0522d;
      text-transform: capitalize;
      text-decoration: overline;
    }
    .dish-name {
      font-size: 20px;
      font-weight: bold;
      color: #4b0082;
      text-transform: capitalize;
    }
    .dish-name:hover {
      transform: scale(1.1);
    }
    .dish-description {
      font-size: 15px;
      line-height: 1.6;
      text-indent: 30px;
      color: #555555;
    }
    .special-offer {
      font-size: 22px;
      font-weight: bold;
      color: #ffffff;
      background-color: #b22222;
      text-align: center;
      text-transform: uppercase;
      text-shadow: 2px 2px 3px #000000;
      box-shadow: 0 0 12px #b22222;
      transform: rotate(-2deg);
    }
  </style>
</head>
<body>
  <div class="menu-card">
    <h1 class="topic">my dream career</h1>
    <p class="tagline">my future career</p>
    <div class="menu-section">
      <h2 class="section-title">career</h2>
      <p class="dish-name">engenier</p>
      <p class="dish-name">docter</p>
    </div>
    <div class="menu-section">
      <h2 class="section-title">buissness</h2>
      <p class="dish-name">car shop</p>
      <p class="dish-name">trade</p>
  </div>
</body>
</html>