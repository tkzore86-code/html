            font-family: Arial, sans-serif;
        }
        .page-header {
            background-image: linear-gradient(to right, purple, coral);
            border-radius: 16px;
            text-align: center;
            color: white;
        }
        .fact-card {
            background-color: midnightblue;;
            border-radius: 12px;
            color: white;
        }
