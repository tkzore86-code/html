<html>
    <head>
        <title>my food menu</title>
    <style>
        body {
            font-family: arial;
            background: #fff8f0;
            padding: 30px;
            text-align: center;
        }
        h1 { color: #e65c00;}
        h1 + p {
            background: #ffe0b2;
            padding: 10px 20px;
            border-radius: 8px;
            color: #bf360c;
            display: inline-block;
        }
        ul { padding: 0; margin-top: 20px;}
        ul > li {
            list-style: none;
            font-size: 18px;
            font-weight: bold;
            color: #5d4037;
            padding: 10px 20px;
            margin: 6px auto;
            width: 260px;
            background: #ff3e08;
            border-radius: 8px;
        }
        ul li:nth-child(3) {
            background: #ffe082;
            color: #ffe082;
        }
        .desc {
            color: #555;
            margin-top: 20px;
            font-size: 15px;
            max-width: 400px;
            margin-right: auto;
        }
        .desc::first-letter{
            font-size: 220%;
            color: #e65c00;
            font-weight: bold;
        }
        .links {margin-top: 25px;}
        a {
            color: #e65c00;
            text-decoration: none;
            font-size: 15px;
            margin: 0 12px;
            padding: 8px 18px;
            border: 2px solid #e65c00;
            border-radius: 8px;
        }
        a:hover {
            background: #e65c00;
            color: white;
        }
    </style>
</head>
<body>
    <h1>my food menu</h1>
    <p>pick your favourite dish and dig in!</p>
    <ul>
        <li>pizza</li>
        <li>burger</li>
        <li>tacos-chef's special!</li>
        <li>noodles</li>
        <li>Ice cream</li>
    </ul>
</body>
</html>